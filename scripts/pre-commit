#!/usr/bin/env bash
set -euo pipefail

# --- Submodule freshness check ---
# Warn if AccessibilitySnapshotBH doesn't track the tip of main.
# .gitmodules declares branch = main; this fetches to check, but does NOT
# auto-stage — the developer must update and commit the pin intentionally.
if git submodule update --remote --quiet -- submodules/AccessibilitySnapshotBH 2>/dev/null; then
    submodule_dirty=$(git diff --name-only -- submodules/AccessibilitySnapshotBH)
    if [[ -n "$submodule_dirty" ]]; then
        echo "warning: AccessibilitySnapshotBH submodule is behind the tip of main"
        echo "Run: git submodule update --remote -- submodules/AccessibilitySnapshotBH && git add submodules/AccessibilitySnapshotBH"
    fi
fi

# --- Tuist project freshness check ---
if command -v tuist >/dev/null 2>&1; then
    # Ensure external dependencies are fetched before generating
    tuist install >/dev/null 2>&1 || true
    if tuist generate --no-open --no-binary-cache >/dev/null 2>&1; then
        # Auto-clean pbxproj noise that tuist (and Xcode UI edits) leak in:
        # hardcoded SRCROOT, duplicated header search paths, etc.
        find . -name 'project.pbxproj' \
            -not -path './Tuist/.build/*' \
            -not -path './submodules/*' \
            -not -path './.context/*' \
            -print0 | xargs -0 python3 scripts/clean-pbxproj.py >/dev/null \
            || echo "warning: scripts/clean-pbxproj.py exited non-zero; pbxproj noise may not be stripped"

        dirty=$(git diff --name-only -- '*.pbxproj' '*.xcworkspacedata' '*.xcscheme')
        if [[ -n "$dirty" ]]; then
            echo "error: tuist generate produced uncommitted project changes:"
            echo "$dirty"
            echo "Run scripts/generate-project.sh and stage the result, or investigate."
            exit 1
        fi
    else
        echo "warning: tuist generate failed, skipping project freshness check"
    fi
fi

# --- Hardcoded absolute paths in pbxproj ---
abs_paths=$(git diff --cached -- '*.pbxproj' | grep '^+' | grep -v '^+++' | grep 'SRCROOT = /Users' || true)
if [[ -n "$abs_paths" ]]; then
    echo "error: staged pbxproj files contain hardcoded absolute paths:"
    echo "$abs_paths"
    echo "Hardcoded SRCROOT breaks builds for other developers and CI."
    echo "Investigate the Tuist configuration — do not commit these paths."
    exit 1
fi

# --- SwiftLint ---
if ! command -v swiftlint >/dev/null 2>&1; then
    echo "warning: SwiftLint not installed, skipping pre-commit lint"
    exit 0
fi

# Lint the entire repo — matches CI behavior.
# Staged-only lint misses pre-existing violations in unmodified files.
swiftlint lint --strict --quiet

# If Tuist config files are staged, regenerate and verify no drift
tuist_files=$(git diff --cached --name-only --diff-filter=ACM -- 'Project.swift' '*/Project.swift' 'Workspace.swift' 'Tuist.swift' 'Tuist/Package.swift' 'Tuist/ProjectDescriptionHelpers/*.swift')
if [[ -n "$tuist_files" ]]; then
    echo "Tuist config changed — regenerating to check for drift..."
    tuist install >/dev/null 2>&1 || true
    if tuist generate --no-open --no-binary-cache >/dev/null 2>&1; then
        find . -name 'project.pbxproj' \
            -not -path './Tuist/.build/*' \
            -not -path './submodules/*' \
            -not -path './.context/*' \
            -print0 | xargs -0 python3 scripts/clean-pbxproj.py >/dev/null \
            || echo "warning: scripts/clean-pbxproj.py exited non-zero; pbxproj noise may not be stripped"

        drift=$(git diff --name-only -- '*.pbxproj' '*.xcworkspacedata')
        if [[ -n "$drift" ]]; then
            echo "error: tuist generate produced unstaged changes:"
            echo "$drift"
            echo "Run scripts/generate-project.sh and stage the result before committing."
            exit 1
        fi
    else
        echo "warning: tuist generate failed, skipping drift check"
    fi
fi
