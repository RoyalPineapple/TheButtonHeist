#!/usr/bin/env bash
set -euo pipefail

# --- Tuist project freshness check ---
if command -v tuist >/dev/null 2>&1; then
    tuist generate --no-open >/dev/null 2>&1
    dirty=$(git diff --name-only -- '*.pbxproj' '*.xcworkspacedata' '*.xcscheme')
    if [[ -n "$dirty" ]]; then
        echo "error: tuist generate produced uncommitted project changes:"
        echo "$dirty"
        echo "Stage them (git add -- '*.pbxproj' '*.xcworkspacedata') or investigate."
        exit 1
    fi
fi

# --- SwiftLint ---
if ! command -v swiftlint >/dev/null 2>&1; then
    echo "warning: SwiftLint not installed, skipping pre-commit lint"
    exit 0
fi

# Lint only staged Swift files
staged=$(git diff --cached --name-only --diff-filter=ACM -- '*.swift')
if [[ -z "$staged" ]]; then
    exit 0
fi

swiftlint lint --strict --quiet -- $staged

# If Tuist config files are staged, regenerate and verify no drift
tuist_files=$(git diff --cached --name-only --diff-filter=ACM -- 'Project.swift' '*/Project.swift' 'Workspace.swift' 'Tuist.swift' 'Tuist/Package.swift' 'Tuist/ProjectDescriptionHelpers/*.swift')
if [[ -n "$tuist_files" ]]; then
    echo "Tuist config changed — regenerating to check for drift..."
    tuist generate --no-open >/dev/null 2>&1
    drift=$(git diff --name-only -- '*.pbxproj' '*.xcworkspacedata')
    if [[ -n "$drift" ]]; then
        echo "error: tuist generate produced unstaged changes:"
        echo "$drift"
        echo "Stage the regenerated project files before committing."
        exit 1
    fi
fi
