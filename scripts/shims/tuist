#!/usr/bin/env bash
# Repo-local Tuist shim.
#
# Tuist 4.40.0 can leave generated project files dirty after commands that
# touch the Xcode graph. Keep the real Tuist behavior, then scrub generated
# pbxproj noise so worktree-specific paths never stick around.

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

path_without_shim=""
IFS=: read -r -a path_parts <<< "${PATH:-}"
for path_part in "${path_parts[@]}"; do
    normalized_path_part="$path_part"
    if [[ -n "$path_part" && -d "$path_part" ]]; then
        normalized_path_part="$(cd "$path_part" && pwd)"
    fi

    if [[ "$normalized_path_part" == "$SCRIPT_DIR" ]]; then
        continue
    fi

    if [[ -z "$path_without_shim" ]]; then
        path_without_shim="$path_part"
    else
        path_without_shim="$path_without_shim:$path_part"
    fi
done

real_tuist="$(PATH="$path_without_shim" command -v tuist || true)"
if [[ -z "$real_tuist" ]]; then
    echo "error: real tuist binary not found after removing $SCRIPT_DIR from PATH" >&2
    exit 127
fi

subcommand="${1:-}"
PATH="$path_without_shim" "$real_tuist" "$@"
tuist_status=$?

is_help=false
for arg in "$@"; do
    if [[ "$arg" == "--help" || "$arg" == "-h" ]]; then
        is_help=true
        break
    fi
done

clean_status=0
case "$subcommand" in
    generate)
        if [[ "${BUTTONHEIST_TUIST_SKIP_AUTO_CLEAN:-}" != "1" && "$is_help" == false ]]; then
            "$REPO_ROOT/scripts/clean-generated-projects.sh" || clean_status=$?
        fi
        ;;
    test)
        if [[ "${BUTTONHEIST_TUIST_SKIP_AUTO_CLEAN:-}" != "1" && "$is_help" == false ]]; then
            PATH="$path_without_shim" "$real_tuist" generate --no-open --no-binary-cache
            generate_status=$?
            "$REPO_ROOT/scripts/clean-generated-projects.sh" || clean_status=$?
            if [[ "$clean_status" -eq 0 ]]; then
                clean_status=$generate_status
            fi
        fi
        ;;
esac

if [[ "$tuist_status" -ne 0 ]]; then
    exit "$tuist_status"
fi

exit "$clean_status"
