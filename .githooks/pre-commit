#!/bin/bash

if ! command -v swiftlint &> /dev/null; then
    echo "warning: SwiftLint not installed, skipping pre-commit lint"
    exit 0
fi

# Lint only staged Swift files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.swift$')

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

# Run SwiftLint --fix on staged files, then re-stage them
echo "$STAGED_FILES" | while read -r file; do
    if [ -f "$file" ]; then
        swiftlint --fix --quiet -- "$file"
        git add "$file"
    fi
done

# Lint staged files and fail on errors
LINT_OUTPUT=$(echo "$STAGED_FILES" | xargs swiftlint lint --quiet -- 2>&1)

if [ -n "$LINT_OUTPUT" ]; then
    echo "$LINT_OUTPUT"
    # Only block commit on errors, not warnings
    if echo "$LINT_OUTPUT" | grep -q ': error:'; then
        echo ""
        echo "SwiftLint errors found. Fix them before committing."
        exit 1
    fi
fi

exit 0
