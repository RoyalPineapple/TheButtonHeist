{
  "version": 5,
  "app": "com.buttonheist.testapp",
  "steps": [
    {
      "command": "activate",
      "target": {
        "label": "Controls Demo",
        "traits": [
          "button"
        ]
      },
      "arguments": {
        "expect": {
          "type": "screen_changed"
        }
      }
    },
    {
      "command": "activate",
      "target": {
        "label": "Display",
        "traits": [
          "button"
        ]
      },
      "arguments": {
        "expect": {
          "type": "screen_changed"
        }
      }
    },
    {
      "command": "activate",
      "target": {
        "label": "Controls Demo",
        "traits": [
          "button",
          "backButton"
        ]
      },
      "arguments": {
        "expect": {
          "type": "screen_changed"
        }
      }
    }
  ]
}
