{
  "version": 6,
  "app": "com.buttonheist.testapp",
  "steps": [
    {
      "command": "activate",
      "target": {
        "label": "Controls Demo",
        "traits": [
          "button"
        ]
      },
      "expectation": {
        "type": "screen_changed"
      }
    },
    {
      "command": "activate",
      "target": {
        "label": "Display",
        "traits": [
          "button"
        ]
      },
      "expectation": {
        "type": "screen_changed"
      }
    },
    {
      "command": "activate",
      "target": {
        "label": "Controls Demo",
        "traits": [
          "button",
          "backButton"
        ]
      },
      "expectation": {
        "type": "screen_changed"
      }
    }
  ]
}
